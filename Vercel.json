{
  "framework": "nextjs",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_WEBAPP_URL": "@webapp-url"
    }
  },
  "env": {
    "TELEGRAM_TOKEN": "@telegram-token-secret",
    "DATABASE_URL": "@database-url-secret"
  },
  "routes": [
    {
      "src": "/sprite.gif",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Content-Security-Policy": "frame-ancestors 'self' https://*.telegram.org https://health-throne.vercel.app;"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/_next/:path*",
      "destination": "/api/:path*"
    }
  ]
}
